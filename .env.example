# ─────────────────────────────────────────────
#  CertifyGRC — Environment Variables Template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Client (Vite) — integrations (Google Drive, OneDrive, SharePoint, Dropbox, Box)
# Base URL of the service that runs OAuth and stores tokens server-side. The app calls:
#   GET {VITE_INTEGRATIONS_API_URL}/v1/integrations/{providerId}/oauth/start?return_to=...
# Leave unset in local dev if you are not running that service yet; the UI will show setup-required
# and local evidence upload still works.
# VITE_INTEGRATIONS_API_URL=https://api.example.com
